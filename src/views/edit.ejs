<html lang="pt-br">
  <%- include('./patials/head.ejs') %>
  <body>
    <%- include('./patials/navbar.ejs') %>
    <div class="content content-single">
      <form class="user-form compact-form" action="/users/<%= user._id %>/edit" method="POST">
        <h3 class="form-title">Editar usuário</h3>
        <div class="form-grid">
          <input type="text" name="firstName" value="<%= user.firstName %>" placeholder="Primeiro nome" required />
          <input type="text" name="lastName" value="<%= user.lastName %>" placeholder="Sobrenome" required />
          <input type="email" name="email" value="<%= user.email %>" placeholder="Email" required />
          <input type="password" name="password" value="<%= user.password %>" placeholder="Senha" minlength="7" required />
        </div>
        <div class="form-actions">
          <button class="action-button edit-button" type="submit">Salvar edição</button>
          <a class="action-button secondary-button" href="/views">Cancelar</a>
        </div>
      </form>
    </div>
  </body>
</html>
